SOUNDBANK_ENABLED=true
SOUNDBANK_SHOW_STARTER_DEMOS=true
SOUNDBANK_INIT_DB=false
SOUNDBANK_SEED_BETA_ORIGINALS=false
SOUNDBANK_FAKE_CHECKOUT_ENABLED=false
SOUNDBANK_ALLOW_PUBLIC_MASTER_URLS=false
SOUNDBANK_PUBLIC_BASE_URL=http://127.0.0.1:5000
DATABASE_SSLMODE=require

# Set these only for an isolated SoundBank database or protected admin session.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# ADMIN_TOKEN=replace-with-a-local-secret
# ADMIN_ALLOWED_IPS=
# ADMIN_IP_ALLOWLIST_REQUIRED=false

# Payment secrets for the standalone SoundBank merchant flow.
# SOUNDBANK_SIGNING_SECRET=replace-with-random-secret
# SOUNDBANK_PAYMENT_WEBHOOK_SECRET=replace-with-random-secret
# SOUNDBANK_ECPAY_MERCHANT_ID=
# SOUNDBANK_ECPAY_HASH_KEY=
# SOUNDBANK_ECPAY_HASH_IV=
# SOUNDBANK_ECPAY_PAYMENT_URL=
# SOUNDBANK_ECPAY_CHOOSE_PAYMENT=Credit
# SOUNDBANK_ECPAY_AUTOSUBMIT=false
# SOUNDBANK_ECPAY_ACCEPT_SIMULATED=false

# Object storage for private master files. Keep master files out of /static.
# SOUNDBANK_OBJECT_STORAGE_ACCESS_KEY_ID=
# SOUNDBANK_OBJECT_STORAGE_SECRET_ACCESS_KEY=
# SOUNDBANK_OBJECT_STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# SOUNDBANK_OBJECT_STORAGE_REGION=auto
# SOUNDBANK_OBJECT_STORAGE_SIGNED_URL_TTL_SECONDS=300
